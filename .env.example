# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# RunPod pod public URL (set after pod starts)
# e.g. https://abc123-8000.proxy.runpod.net
RUNPOD_SERVER_URL=https://YOUR_POD_ID-8000.proxy.runpod.net

# Optional: RunPod API key for programmatic pod management
RUNPOD_API_KEY=

# Search config
MAX_GENERATIONS=10
CANDIDATES_PER_GENERATION=10
TOP_K=3
CONVERGENCE_THRESHOLD_PCT=2.0
